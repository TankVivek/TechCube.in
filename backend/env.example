# Backend Environment Variables
PORT=3000
NODE_ENV=development

# CORS Configuration
CORS_ORIGIN=http://localhost:3001,https://techcube.in

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=your-email@gmail.com

# Database Configuration
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/techcube?retryWrites=true&w=majority

# Security
JWT_SECRET=your-jwt-secret-key
SESSION_SECRET=your-session-secret

# Firebase Push Notifications (Optional - for Admin Alerts)
# Paste the entire JSON content of your service account key file as a single string
FIREBASE_SERVICE_ACCOUNT={"type": "service_account", "project_id": "...", ...} 